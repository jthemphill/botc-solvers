{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2022"],
    "types": ["bun-types"],
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true
  },
  "include": ["src/**/*.ts", "src/**/*.json", "tests/**/*.ts", "vendor/**/*.ts"],
  "exclude": ["tests/e2e/**/*.ts"]
}
