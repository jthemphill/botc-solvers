{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2022", "DOM", "WebWorker"],
    "types": ["vite/client"],
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.json", "vendor/**/*.ts"],
  "exclude": ["src/model/puzzles/**/*.ts", "src/**/*.test.ts", "src/**/*.test.tsx"]
}
