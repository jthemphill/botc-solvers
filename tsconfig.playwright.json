{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2022", "DOM"],
    "noEmit": true,
    "types": ["bun"]
  },
  "include": [
    "tests/e2e/**/*.ts",
    "src/dsl/**/*.ts",
    "src/model/**/*.ts",
    "src/schema/**/*.ts",
    "src/state/**/*.ts",
    "src/worker/protocol.ts",
    "vendor/**/*.ts"
  ],
  "exclude": ["src/**/*.test.ts"]
}
