{
  "name": "botc-solver-typescript",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun test",
    "typecheck": "bunx tsc --build tsconfig.json --pretty false",
    "puzzle:01": "bun run src/puzzles/puzzle-01-sober-savant.ts",
